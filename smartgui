def get_seasonal_context(sel_date):
    d = sel_date
    if date(d.year, 9, 1) <= d <= date(d.year, 11, 20):
        return "ΠΕΡΙΟΔΟΣ 1"
    if d >= date(d.year, 11, 21) or d <= date(d.year, 1, 31):
        return "ΠΕΡΙΟΔΟΣ 2"
    return "ΕΚΤΟΣ ΠΕΡΙΟΔΟΥ"


