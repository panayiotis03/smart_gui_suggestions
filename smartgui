def select_folder():
    """Επιλογή φακέλου — αν δεν περιέχει drakos/tasos/Tofis,
    ψάχνει αυτόματα για υποφάκελο 'thesis'."""
    chosen = filedialog.askdirectory()
    if not chosen:
        return

    # Έλεγχος αν ο επιλεγμένος φάκελος έχει την αναμενόμενη δομή
    expected = ['drakos', 'tasos', 'Tofis', 'tofis']
    has_structure = any(
        os.path.isdir(os.path.join(chosen, d)) for d in expected
    )

    if not has_structure:
        # Ψάξε για υποφάκελο "thesis"
        thesis_sub = os.path.join(chosen, 'thesis')
        if os.path.isdir(thesis_sub) and any(
            os.path.isdir(os.path.join(thesis_sub, d)) for d in expected
        ):
            chosen = thesis_sub
            folder_label.config(
                text=f"📁 {chosen}  ✅", fg='#27AE60'
            )
        else:
            folder_label.config(
                text=f"⚠️  Δεν βρέθηκε δομή drakos/tasos/Tofis στο: {chosen}",
                fg='#C0392B'
            )
    else:
        folder_label.config(text=f"📁 {chosen}  ✅", fg='#27AE60')

    folder_path.set(chosen)

