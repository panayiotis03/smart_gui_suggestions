def find_sensor_csv(base_path, room, part, month_num):
    aliases = MONTH_FILE_ALIASES.get(month_num, [])

    if room == "TOFIS":
        search_dirs = [
            os.path.join(base_path, "Tofis"),
            os.path.join(base_path, "tofis"),
            base_path,
        ]
    elif room == "DRAKOS":
        # Ο φάκελος είναι "drakos front" ή "drakos back" (lowercase)
        part_lower = part.lower()   # "front" ή "back"
        search_dirs = [
            os.path.join(base_path, "drakos", f"drakos {part_lower}"),
            os.path.join(base_path, "drakos"),
            base_path,
        ]
    elif room == "TASOS":
        # Front_Right/Back_Left μοιράζονται sensor με Front_Left/Back_Right
        sensor_folder = TASOS_SENSOR_FOLDER.get(part, f"TASOS_{part.lower()}")
        search_dirs = [
            os.path.join(base_path, "tasos", sensor_folder),
            os.path.join(base_path, "tasos"),
            base_path,
        ]
    else:
        search_dirs = [base_path]

    for d in search_dirs:
        if not os.path.isdir(d):
            continue
        for f in os.listdir(d):
            name_no_ext = os.path.splitext(f)[0].lower()
            if f.lower().endswith('.csv') and 'feedback' not in f.lower():
                if name_no_ext in aliases:
                    return os.path.join(d, f)
    return None


def find_feedback_csv(base_path, room, part, month_num):
    fb_month = MONTH_FEEDBACK_NAME.get(month_num, '')

    if room == "TOFIS":
        candidates = [f"TOFIS_{fb_month}_feedbacks.csv"]
        search_dirs = [
            os.path.join(base_path, "Tofis"),
            os.path.join(base_path, "tofis"),
            base_path,
        ]
    elif room == "DRAKOS":
        candidates = [f"DRAKOS_{part}_{fb_month}_feedbacks.csv"]
        search_dirs = [
            os.path.join(base_path, "drakos"),
            base_path,
        ]
    elif room == "TASOS":
        candidates = [f"TASOS_{part}_{fb_month}_feedbacks.csv"]
        search_dirs = [
            os.path.join(base_path, "tasos"),
            base_path,
        ]
    else:
        candidates = []
        search_dirs = [base_path]

    for d in search_dirs:
        if not os.path.isdir(d):
            continue
        for f in os.listdir(d):
            for c in candidates:
                if f.lower() == c.lower():
                    return os.path.join(d, f)
    return None


# =============================================================================
#  DECISION TREE  –  ΠΕΡΙΟΔΟΣ 1: Θερμή / Μεταβατική (Σεπ – 20 Νοε)
# =============================================================================
def decision_tree_p1(v, comfort_pct, total_f):
    """
    Περίοδος 1: Θερμή/Μεταβατική
    Αερισμός: άνοιγμα παραθύρων επιτρεπτό
    T: 23–27°C | H: 40–60% (αποδ. 30–65%) | CO2: <1000 ok, 1000–1500 μέτριο, >1500 κακό
    VOC: <300 ok μg/m³, 300–500 αποδεκτό, 500–1000 μέτριο, >1000 κακό (WHO/IAQ)
    """
    results = []

    # ── 1. TEMPERATURE ────────────────────────────────────────────────────────
    T = v.get('T')
    if T == "N/A" or T is None:
        results.append(('info', "Θερμοκρασία: Δεν υπάρχουν δεδομένα."))
    elif T < 23:
        results.append(('warn',
            f"Θερμοκρασία ({T} °C) → Μείωση κλιματισμού ή κλείσιμο παραθύρων."))
    elif T <= 27:
        results.append(('ok',
            f"Θερμοκρασία ({T} °C) βέλτιστη για Περίοδο 1 (23–27°C, ASHRAE)."))
    else:
        results.append(('alert',
            f"Θερμοκρασία ({T} °C) → Άνοιγμα παραθύρων ή ενεργοποίηση A/C."))

    # ── 2. HUMIDITY ───────────────────────────────────────────────────────────
    H = v.get('H')
    if H == "N/A" or H is None:
        results.append(('info', "Υγρασία: Δεν υπάρχουν δεδομένα."))
    elif H < 30:
        results.append(('alert',
            f"Υγρασία ({H} %) → Χρήση υγραντήρα ή λειτουργία υγρασίας A/C."))
    elif H < 40:
        results.append(('warn',
            f"Υγρασία ({H} %) → Ελαφρά χαμηλή, συνιστάται αύξηση υγρασίας."))
    elif H <= 60:
        results.append(('ok',
            f"Υγρασία ({H} %) βέλτιστη για Περίοδο 1 (40–60%, ASHRAE)."))
    elif H <= 65:
        results.append(('warn',
            f"Υγρασία ({H} %) → Ελαφρύ άνοιγμα παραθύρων ή χρήση αφυγραντήρα."))
    else:
        results.append(('alert',
            f"Υγρασία ({H} %) → Άνοιγμα παραθύρων & χρήση αφυγραντήρα."))

    # ── 3. CO2 ────────────────────────────────────────────────────────────────
    C = v.get('C')
    if C == "N/A" or C is None:
        results.append(('info', "CO2: Δεν υπάρχουν δεδομένα."))
    elif C < 600:
        results.append(('ok',
            f"CO2 ({C} ppm) → Εξαιρετική ποιότητα αέρα."))
    elif C <= 1000:
        results.append(('ok',
            f"CO2 ({C} ppm) → Καλό επίπεδο για Περίοδο 1."))
    elif C <= 1500:
        results.append(('warn',
            f"CO2 ({C} ppm) → Άνοιγμα παραθύρων για φυσικό αερισμό."))
    else:
        results.append(('alert',
            f"CO2 ({C} ppm) → Άμεσος αερισμός – άνοιγμα παραθύρων & πόρτων."))

    # ── 4. VOC ────────────────────────────────────────────────────────────────
    VOC = v.get('VOC')
    if VOC == "N/A" or VOC is None:
        results.append(('info', "VOC: Δεν υπάρχουν δεδομένα."))
    else:
        voc_ugm3 = round(VOC * 3, 0)
        if voc_ugm3 < 300:
            results.append(('ok',
                f"VOC ({VOC} ppb ≈ {voc_ugm3:.0f} μg/m³) → Αποδεκτή ποιότητα."))
        elif voc_ugm3 <= 500:
            results.append(('warn',
                f"VOC ({VOC} ppb ≈ {voc_ugm3:.0f} μg/m³) → Αύξηση αερισμού μέσω ανοίγματος παραθύρων."))
        elif voc_ugm3 <= 1000:
            results.append(('warn',
                f"VOC ({VOC} ppb ≈ {voc_ugm3:.0f} μg/m³) → Έντονος αερισμός – άνοιγμα παραθύρων & πόρτων."))
        else:
            results.append(('alert',
                f"VOC ({VOC} ppb ≈ {voc_ugm3:.0f} μg/m³) → Άμεσος αερισμός & εντοπισμός χημικών πηγών."))

    return results


# =============================================================================
#  DECISION TREE  –  ΠΕΡΙΟΔΟΣ 2: Ψυχρή (20 Νοε – Ιαν)
# =============================================================================
def decision_tree_p2(v, comfort_pct, total_f):
    """
    Περίοδος 2: Ψυχρή
    Αερισμός: ΜΟΝΟ HVAC/A/C – ΟΧΙ άνοιγμα παραθύρων
    T: 20–24°C | H: 30–50% (αποδ. 30–60%) | CO2: <1200 ok, 1200–1500 μέτριο, >1500 κακό
    VOC: ίδια κατώφλια με Π1 (WHO/IAQ)
    """
    results = []

    # ── 1. TEMPERATURE ────────────────────────────────────────────────────────
    T = v.get('T')
    if T == "N/A" or T is None:
        results.append(('info', "Θερμοκρασία: Δεν υπάρχουν δεδομένα."))
    elif T < 20:
        results.append(('alert',
            f"Θερμοκρασία ({T} °C) → Αύξηση θέρμανσης & κλείσιμο παραθύρων."))
    elif T <= 24:
        results.append(('ok',
            f"Θερμοκρασία ({T} °C) βέλτιστη για Περίοδο 2 (20–24°C, ASHRAE)."))
    else:
        results.append(('warn',
            f"Θερμοκρασία ({T} °C) → Μείωση θέρμανσης ή χρήση HVAC/A/C."))

    # ── 2. HUMIDITY ───────────────────────────────────────────────────────────
    H = v.get('H')
    if H == "N/A" or H is None:
        results.append(('info', "Υγρασία: Δεν υπάρχουν δεδομένα."))
    elif H < 30:
        results.append(('alert',
            f"Υγρασία ({H} %) → Χρήση υγραντήρα (τάση μείωσης υγρασίας χειμερινής περιόδου)."))
    elif H <= 50:
        results.append(('ok',
            f"Υγρασία ({H} %) βέλτιστη για Περίοδο 2 (30–50%, ASHRAE)."))
    elif H <= 60:
        results.append(('warn',
            f"Υγρασία ({H} %) → Χρήση αφυγραντήρα ή HVAC/A/C."))
    else:
        results.append(('alert',
            f"Υγρασία ({H} %) → Χρήση αφυγραντήρα ή HVAC/A/C."))

    # ── 3. CO2 ────────────────────────────────────────────────────────────────
    C = v.get('C')
    if C == "N/A" or C is None:
        results.append(('info', "CO2: Δεν υπάρχουν δεδομένα."))
    elif C < 1000:
        results.append(('ok',
            f"CO2 ({C} ppm) → Καλό επίπεδο για Περίοδο 2."))
    elif C <= 1200:
        results.append(('ok',
            f"CO2 ({C} ppm) → Αποδεκτό επίπεδο χειμερινών συνθηκών."))
    elif C <= 1500:
        results.append(('warn',
            f"CO2 ({C} ppm) → Ενεργοποίηση μηχανικού εξαερισμού HVAC/A/C."))
    else:
        results.append(('alert',
            f"CO2 ({C} ppm) → Άμεση ενεργοποίηση HVAC/A/C."))

    # ── 4. VOC ────────────────────────────────────────────────────────────────
    VOC = v.get('VOC')
    if VOC == "N/A" or VOC is None:
        results.append(('info', "VOC: Δεν υπάρχουν δεδομένα."))
    else:
        voc_ugm3 = round(VOC * 3, 0)
        if voc_ugm3 < 300:
            results.append(('ok',
                f"VOC ({VOC} ppb ≈ {voc_ugm3:.0f} μg/m³) → Αποδεκτή ποιότητα."))
        elif voc_ugm3 <= 500:
            results.append(('warn',
                f"VOC ({VOC} ppb ≈ {voc_ugm3:.0f} μg/m³) → Αύξηση αερισμού μέσω HVAC/A/C."))
        elif voc_ugm3 <= 1000:
            results.append(('warn',
                f"VOC ({VOC} ppb ≈ {voc_ugm3:.0f} μg/m³) → Ενεργοποίηση HVAC/A/C & αποφυγή χημικών πηγών."))
        else:
            results.append(('alert',
                f"VOC ({VOC} ppb ≈ {voc_ugm3:.0f} μg/m³) → Άμεση ενεργοποίηση HVAC/A/C & εντοπισμός χημικών πηγών."))

    return results


# =============================================================================
#  ΚΟΙΝΕΣ ΠΑΡΑΜΕΤΡΟΙ  –  PM1, PM2.5, Θόρυβος, Πίεση (ίδιες και στις 2 περιόδους)
# =============================================================================
def decision_tree_common(v, comfort_pct, total_f, P1):
    """PM1, PM2.5, Noise, Pressure – ίδια κατώφλια και στις 2 περιόδους."""
    results = []

    # ── PM1 ───────────────────────────────────────────────────────────────────
    PM1 = v.get('PM1')
    if PM1 == "N/A" or PM1 is None:
        results.append(('info', "PM1: Δεν υπάρχουν δεδομένα."))
    elif PM1 < 10:
        results.append(('ok',
            f"PM1 ({PM1} μg/m³) < 10 μg/m³ → Καθαρός αέρας."))
    elif PM1 <= 20:
        if P1:
            results.append(('warn',
                f"PM1 ({PM1} μg/m³) 10–20 μg/m³ → Αύξηση φιλτραρίσματος αέρα μέσω ανοίγματος παραθύρων."))
        else:
            results.append(('warn',
                f"PM1 ({PM1} μg/m³) 10–20 μg/m³ → Χρήση φίλτρου αέρα / HVAC."))
    else:
        if P1:
            results.append(('alert',
                f"PM1 ({PM1} μg/m³) > 20 μg/m³ → Άμεσος αερισμός & χρήση καθαριστή αέρα."))
        else:
            results.append(('alert',
                f"PM1 ({PM1} μg/m³) > 20 μg/m³ → Χρήση καθαριστή αέρα / HVAC – αποφύγετε άνοιγμα παραθύρων."))

    # ── PM2.5 ─────────────────────────────────────────────────────────────────
    PM25 = v.get('PM25')
    if PM25 == "N/A" or PM25 is None:
        results.append(('info', "PM2.5: Δεν υπάρχουν δεδομένα."))
    elif PM25 < 12:
        results.append(('ok',
            f"PM2.5 ({PM25} μg/m³) < 12 μg/m³ → Καλή ποιότητα αέρα (WHO)."))
    elif PM25 <= 25:
        if P1:
            results.append(('warn',
                f"PM2.5 ({PM25} μg/m³) 12–25 μg/m³ → Αύξηση αερισμού μέσω ανοίγματος παραθύρων."))
        else:
            results.append(('warn',
                f"PM2.5 ({PM25} μg/m³) 12–25 μg/m³ → Χρήση καθαριστή αέρα / HVAC."))
    else:
        if P1:
            results.append(('alert',
                f"PM2.5 ({PM25} μg/m³) > 25 μg/m³ → Άμεσος αερισμός & χρήση καθαριστή αέρα."))
        else:
            results.append(('alert',
                f"PM2.5 ({PM25} μg/m³) > 25 μg/m³ → Άμεση χρήση καθαριστή αέρα / HVAC – αποφύγετε άνοιγμα παραθύρων."))

    # ── NOISE ─────────────────────────────────────────────────────────────────
    N = v.get('N')
    if N == "N/A" or N is None:
        results.append(('info', "Θόρυβος: Δεν υπάρχουν δεδομένα."))
    elif N < 35:
        results.append(('ok',
            f"Θόρυβος ({N} dBA) < 35 dBA → Ήσυχο περιβάλλον."))
    elif N <= 50:
        results.append(('warn',
            f"Θόρυβος ({N} dBA) 35–50 dBA → Κλείσιμο παραθύρων για μείωση εξωτερικού θορύβου."))
    else:
        results.append(('alert',
            f"Θόρυβος ({N} dBA) > 50 dBA → Εντοπισμός & μείωση πηγών θορύβου, κλείσιμο παραθύρων."))

    # ── PRESSURE ──────────────────────────────────────────────────────────────
    P = v.get('P')
    if P == "N/A" or P is None:
        results.append(('info', "Πίεση: Δεν υπάρχουν δεδομένα."))
    elif 980 <= P <= 1050:
        results.append(('ok',
            f"Πίεση ({P} hPa) 980–1050 hPa → Κανονική ατμοσφαιρική πίεση."))
    else:
        results.append(('alert',
            f"Πίεση ({P} hPa) εκτός ορίων (980–1050 hPa) → Ανίχνευση ατμοσφαιρικής αλλαγής, παρακολούθηση."))

    # ── STUDENT SATISFACTION ──────────────────────────────────────────────────
    if total_f >= 3 and comfort_pct is not None:
        if comfort_pct < 40:
            results.append(('alert',
                f"Ικανοποίηση φοιτητών ({comfort_pct:.1f}%) → Χαμηλή άνεση, απαιτείται παρέμβαση."))
        elif comfort_pct < 65:
            results.append(('warn',
                f"Ικανοποίηση φοιτητών ({comfort_pct:.1f}%) → Μέτρια άνεση, παρακολούθηση συνιστάται."))
        else:
            results.append(('ok',
                f"Ικανοποίηση φοιτητών ({comfort_pct:.1f}%) → Υψηλή θερμική άνεση."))

    return results


